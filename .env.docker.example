############################################################
# คัดลอกไฟล์นี้เป็น .env.docker แล้วแก้ค่าทุกตัวที่มี YOUR_
# อย่า commit ไฟล์ .env.docker ขึ้น GitHub เด็ดขาด!
############################################################

# ── Server ────────────────────────────────────────────────
# IP หรือ domain ของ server โรงเรียน (ไม่ต้องมี trailing slash)
SERVER_HOST=http://YOUR_SERVER_IP

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_DB_PASSWORD

# ── JWT / API Keys ────────────────────────────────────────
# สร้างได้ที่: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# ใส่ JWT_SECRET ที่นี่ก่อน แล้ว generate keys

JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRY=3600

SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Dashboard (Supabase Studio) ───────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=YOUR_DASHBOARD_PASSWORD

# ── Next.js (NEXT_PUBLIC_* ต้องตรงกับ server ด้านบน) ─────
NEXT_PUBLIC_SUPABASE_URL=${SERVER_HOST}:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ── Storage ───────────────────────────────────────────────
STORAGE_BACKEND=file
GLOBAL_S3_BUCKET=supa-storage
STORAGE_FILE_SIZE_LIMIT=52428800

# ── Auth (Microsoft SSO — ถ้าไม่ใช้ให้เว้นว่าง) ──────────
GOTRUE_EXTERNAL_AZURE_ENABLED=false
GOTRUE_EXTERNAL_AZURE_CLIENT_ID=
GOTRUE_EXTERNAL_AZURE_SECRET=
GOTRUE_EXTERNAL_AZURE_REDIRECT_URI=${SERVER_HOST}:3000/auth/callback
